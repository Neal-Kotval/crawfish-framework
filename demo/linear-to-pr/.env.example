# Copy to `.env` (same dir) and fill in. The pipeline loads it automatically in --live.
# Real exported shell vars take precedence over this file. Never commit your real .env.

LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
CRAWFISH_PR_REPO=you/sandbox-repo

# Optional: force dry-run even when the creds above are set (e.g. for a fast TRIGGER).
# CRAWFISH_DRY_RUN=1
